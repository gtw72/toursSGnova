{
  "exclude": ["node_modules"],
  "include": ["./Source"],
  "compilerOptions": {
    "incremental": true,
    "target": "ESNext",
    "lib": ["ESNext"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "module": "CommonJS",
    "moduleResolution": "node16",
    "types": ["node"],
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "rootDir": "./Source",
    "importHelpers": true,
    "noEmitHelpers": true,
    "esModuleInterop": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "strictPropertyInitialization": false,
    "alwaysStrict": true,
    "skipLibCheck": true,
    "noErrorTruncation": true,
    "forceConsistentCasingInFileNames": true
  },
  "ts-node": {
    "files": true
  }
}
